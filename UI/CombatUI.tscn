[gd_scene load_steps=2 format=3 uid="uid://com123456789"]

[ext_resource type="Script" path="res://UI/CombatUI.gd" id="1_com"]

[node name="CombatUI" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_com")

[node name="Blocker" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.5)

[node name="Panel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -200.0
offset_right = 300.0
offset_bottom = 200.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 15
alignment = 1

[node name="TitleLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "Tavern Cellar Combat"
horizontal_alignment = 1

[node name="HBoxContainer" type="HBoxContainer" parent="Panel/VBoxContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 50

[node name="PlayerHP" type="Label" parent="Panel/VBoxContainer/HBoxContainer"]
layout_mode = 2
text = "Player HP: 20/20"

[node name="EnemyHP" type="Label" parent="Panel/VBoxContainer/HBoxContainer"]
layout_mode = 2
text = "Rats HP: 10/10"

[node name="CombatLog" type="RichTextLabel" parent="Panel/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
text = "You entered the cellar. Giant rats approach!"
scroll_following = true

[node name="HBoxContainer2" type="HBoxContainer" parent="Panel/VBoxContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 20

[node name="AttackButton" type="Button" parent="Panel/VBoxContainer/HBoxContainer2"]
layout_mode = 2
text = "Attack (d20)"

[node name="FleeButton" type="Button" parent="Panel/VBoxContainer/HBoxContainer2"]
layout_mode = 2
text = "Flee"

[connection signal="pressed" from="Panel/VBoxContainer/HBoxContainer2/AttackButton" to="." method="_on_attack_button_pressed"]
[connection signal="pressed" from="Panel/VBoxContainer/HBoxContainer2/FleeButton" to="." method="_on_flee_button_pressed"]
